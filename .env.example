# Copy to .env and fill in real values.
# docker-compose.yml loads this file automatically.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=https://your-domain.com/webhook
API_KEY=your_llm_api_key
API_URL=http://host.docker.internal:12345/v1
MODEL=smart

# Host port mapped to container :8080
HOST_PORT=8080
